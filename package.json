{
  "name": "cosmio",
  "version": "0.1.0",
  "description": "Type-safe model definition & operation library for Azure Cosmos DB",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "cosmio": "./dist/bin/cosmio.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest --typecheck run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/ tests/",
    "lint:fix": "biome lint --fix src/ tests/",
    "format": "biome format --write src/ tests/ bin/",
    "check": "biome check src/ tests/ bin/",
    "check:fix": "biome check --fix src/ tests/ bin/",
    "docs:dev": "cd docs && npm run dev",
    "docs:build": "cd docs && npm run build",
    "test:compat": "node scripts/test-compat.mjs",
    "emulator:up": "docker compose up -d",
    "emulator:down": "docker compose down",
    "emulator:logs": "docker compose logs -f cosmosdb"
  },
  "peerDependencies": {
    "@azure/cosmos": ">=3.17.2",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@azure/cosmos": "^4.2.0",
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "5.9",
    "vitest": "^4.1.1",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/masahirodev/cosmio.git"
  },
  "homepage": "https://github.com/masahirodev/cosmio#readme",
  "bugs": {
    "url": "https://github.com/masahirodev/cosmio/issues"
  },
  "author": "masahirodev",
  "license": "MIT",
  "keywords": [
    "azure",
    "cosmos-db",
    "cosmosdb",
    "orm",
    "zod",
    "type-safe"
  ]
}
